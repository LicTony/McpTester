<Window x:Class="McpTester.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:vm="clr-namespace:McpTester.ViewModels"
        Title="MCP Tester" Height="720" Width="1280"
        MinHeight="600" MinWidth="1000"
        Background="#1E1E2E" Foreground="#CDD6F4">

    <Window.Resources>
        <!-- Paleta Catppuccin Mocha -->
        <SolidColorBrush x:Key="BgBase"     Color="#1E1E2E"/>
        <SolidColorBrush x:Key="BgMantle"   Color="#181825"/>
        <SolidColorBrush x:Key="BgSurface0" Color="#313244"/>
        <SolidColorBrush x:Key="BgSurface1" Color="#45475A"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#89B4FA"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#A6E3A1"/>
        <SolidColorBrush x:Key="AccentRed"  Color="#F38BA8"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#CDD6F4"/>
        <SolidColorBrush x:Key="TextSubtle"  Color="#6C7086"/>
        <SolidColorBrush x:Key="Overlay"    Color="#6C7086"/>

        <!-- Estilo base de botones -->
        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Background"   Value="#313244"/>
            <Setter Property="Foreground"   Value="#CDD6F4"/>
            <Setter Property="BorderBrush"  Value="#45475A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="12,6"/>
            <Setter Property="Margin"       Value="4,0"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#45475A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#585B70"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botón ejecutar (accent) -->
        <Style x:Key="ExecuteButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="Background"  Value="#1E3A5F"/>
            <Setter Property="BorderBrush" Value="#89B4FA"/>
            <Setter Property="Foreground"  Value="#89B4FA"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="FontSize"    Value="14"/>
            <Setter Property="Padding"     Value="16,8"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A4F80"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TreeView items -->
        <Style TargetType="TreeViewItem">
            <Setter Property="Foreground"    Value="#CDD6F4"/>
            <Setter Property="Background"    Value="Transparent"/>
            <Setter Property="Padding"       Value="4,3"/>
            <Setter Property="FontSize"      Value="13"/>
            <Setter Property="IsExpanded"    Value="True"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#313244"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A2A3E"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- ── TOOLBAR ── -->
        <Border DockPanel.Dock="Top"
                Background="#181825"
                BorderBrush="#313244"
                BorderThickness="0,0,0,1"
                Padding="10,8">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <!-- Logo / título -->
                    <TextBlock Text="⚡ MCP Tester"
                               FontSize="16" FontWeight="Bold"
                               Foreground="#89B4FA"
                               VerticalAlignment="Center"
                               Margin="0,0,20,0"/>

                    <Button x:Name="BtnLoadConfig"
                            Content="📂  Abrir Config"
                            Style="{StaticResource ToolbarButton}"
                            Command="{Binding LoadConfigCommand}"/>

                    <Button x:Name="BtnDisconnect"
                            Content="🔌  Desconectar"
                            Style="{StaticResource ToolbarButton}"
                            Command="{Binding DisconnectCommand}"/>
                </StackPanel>

                <!-- Status derecha -->
                <TextBlock Text="{Binding StatusText}"
                           DockPanel.Dock="Right"
                           VerticalAlignment="Center"
                           Foreground="#A6E3A1"
                           FontSize="12"
                           HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>

        <!-- ── LOG BAR (bottom) ── -->
        <Border DockPanel.Dock="Bottom"
                Background="#181825"
                BorderBrush="#313244"
                BorderThickness="0,1,0,0"
                Height="100">
            <DockPanel Margin="8,6">
                <TextBlock Text="LOG" DockPanel.Dock="Left"
                           VerticalAlignment="Top"
                           Foreground="#6C7086"
                           FontWeight="Bold" FontSize="11"
                           Margin="0,0,10,0"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              x:Name="LogScrollViewer">
                    <TextBlock x:Name="TbLog"
                               Text="{Binding LogText}"
                               Foreground="#BAC2E8"
                               FontFamily="Consolas"
                               FontSize="11"
                               TextWrapping="Wrap"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ── 3 PANELES PRINCIPALES ── -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" MinWidth="160"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*" MinWidth="280"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*" MinWidth="280"/>
            </Grid.ColumnDefinitions>

            <!-- ── PANEL IZQUIERDO: Servidores & Tools ── -->
            <Border Grid.Column="0"
                    Background="#181825"
                    BorderBrush="#313244"
                    BorderThickness="0,0,1,0">
                <DockPanel Margin="8">
                    <TextBlock DockPanel.Dock="Top"
                               Text="SERVIDORES &amp; TOOLS"
                               Foreground="#6C7086"
                               FontWeight="Bold" FontSize="11"
                               Margin="0,0,0,8"/>
                    <TreeView x:Name="TreeServers"
                              Background="Transparent"
                              BorderThickness="0"
                              ItemsSource="{Binding Servers}"
                              SelectedItemChanged="TreeServers_SelectedItemChanged">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Tools}">
                                <!-- Servidor -->
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🖥 " FontSize="12"/>
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="Bold"
                                               Foreground="#89B4FA"
                                               FontSize="13"/>
                                </StackPanel>
                                <!-- Tool (hoja) -->
                                <HierarchicalDataTemplate.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="8,0,0,0">
                                            <TextBlock Text="⚙ " FontSize="11" Foreground="#B4BEFE"/>
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="#CDD6F4"
                                                       FontSize="12"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </HierarchicalDataTemplate.ItemTemplate>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </DockPanel>
            </Border>

            <!-- Splitter 1 -->
            <GridSplitter Grid.Column="1"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          Background="#313244"/>

            <!-- ── PANEL CENTRAL: Tool + Parámetros ── -->
            <Border Grid.Column="2"
                    Background="#1E1E2E">
                <DockPanel Margin="12">
                    <!-- Cabecera tool -->
                    <Border DockPanel.Dock="Top"
                            Background="#181825"
                            CornerRadius="6"
                            Padding="12,8"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="{Binding ToolName, FallbackValue='(Seleccione una tool)'}"
                                       FontWeight="Bold"
                                       FontSize="15"
                                       Foreground="#89B4FA"/>
                            <TextBlock Text="{Binding ToolDescription}"
                                       Foreground="#A6ADC8"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Botón ejecutar -->
                    <Button DockPanel.Dock="Bottom"
                            x:Name="BtnExecute"
                            Content="▶  EJECUTAR"
                            Style="{StaticResource ExecuteButton}"
                            Command="{Binding ExecuteToolCommand}"
                            HorizontalAlignment="Stretch"
                            Margin="0,10,0,0" />

                    <!-- TabControl para separar argumentos y esquema -->
                    <TabControl Background="Transparent" BorderThickness="0" Margin="0,5,0,0">
                        <TabItem Header="Argumentos">
                            <Border BorderBrush="#313244" BorderThickness="1" CornerRadius="0,0,5,5" Margin="0,-1,0,0">
                                <avalonEdit:TextEditor
                                    x:Name="ParamEditor"
                                    FontFamily="Consolas"
                                    FontSize="13"
                                    ShowLineNumbers="True"
                                    Background="#181825"
                                    Foreground="#CDD6F4"
                                    Padding="4"
                                    Height="350"/>
                            </Border>
                        </TabItem>

                        <TabItem Header="Esquema Técnico">
                            <Border BorderBrush="#313244" BorderThickness="1" CornerRadius="0,0,5,5" Margin="0,-1,0,0">
                                <avalonEdit:TextEditor
                                    x:Name="SchemaEditor"
                                    FontFamily="Consolas"
                                    FontSize="12"
                                    ShowLineNumbers="True"
                                    IsReadOnly="True"
                                    Background="#181825"
                                    Foreground="#A6ADC8"
                                    Padding="4"
                                    Height="350"/>
                            </Border>
                        </TabItem>
                    </TabControl>
                </DockPanel>
            </Border>

            <!-- Splitter 2 -->
            <GridSplitter Grid.Column="3"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          Background="#313244"/>

            <!-- ── PANEL DERECHO: Resultado ── -->
            <Border Grid.Column="4"
                    Background="#1E1E2E">
                <DockPanel Margin="12">
                    <!-- Status timing -->
                    <Border DockPanel.Dock="Top"
                            Background="#181825"
                            CornerRadius="6"
                            Padding="10,6"
                            Margin="0,0,0,10">
                        <DockPanel>
                            <TextBlock Text="RESULTADO"
                                       Foreground="#6C7086"
                                       FontWeight="Bold" FontSize="11"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding StatusText}"
                                       DockPanel.Dock="Right"
                                       HorizontalAlignment="Right"
                                       Foreground="#A6E3A1"
                                       FontFamily="Consolas"
                                       FontSize="12"
                                       VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>

                    <!-- AvalonEdit: resultado (readonly) -->
                    <Border BorderBrush="#313244" BorderThickness="1" CornerRadius="5">
                        <avalonEdit:TextEditor
                            x:Name="ResultEditor"
                            FontFamily="Consolas"
                            FontSize="13"
                            ShowLineNumbers="True"
                            IsReadOnly="True"
                            Background="#181825"
                            Foreground="#CDD6F4"
                            Padding="4"/>
                    </Border>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
